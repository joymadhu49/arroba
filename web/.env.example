# ---------------------------------------------------------------------------
# Arroba environment — copy to .env.local and fill in.
# The app renders without any of these (with reduced functionality);
# `npm run build` passes with this file's values absent entirely.
# ---------------------------------------------------------------------------

# Reown (WalletConnect) project ID — get a free one at https://cloud.reown.com
# Without it, the app falls back to a dummy ID: the UI renders but wallet
# connections via the WalletConnect relay won't establish.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Deployed contract addresses on Arc Testnet (chain id 5042002).
# Leave unset (or 0x0) until deployment — the UI shows a
# "contracts not deployed yet" banner and disables on-chain actions.
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_HANDLEPAY_ADDRESS=

# Server-only secret used to derive deterministic tweet-verification codes:
# code = "arc-" + first 10 hex chars of HMAC-SHA256("handle|address", VERIFY_SECRET)
# Use any long random string, e.g. `openssl rand -hex 32`. Never exposed to the client.
VERIFY_SECRET=

# Server-only private key (0x + 64 hex chars) of the attester account that is
# authorized to call HandleRegistry.setVerified(). Fund it with a little
# testnet USDC for gas (https://faucet.circle.com). Never exposed to the client.
ATTESTER_PRIVATE_KEY=
